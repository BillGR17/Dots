{
  "layer": "top",
  "position": "bottom",
  "height": 24,
  "modules-left": [
    "hyprland/workspaces",
    "custom/separator",
    "hyprland/window"
  ],
  "modules-center": [],
  "modules-right": [
    "custom/bandwidth",
    "custom/separator",
    "custom/memory",
    "custom/separator",
    "custom/updates",
    "custom/separator",
    "custom/battery",
    "custom/separator",
    "custom/uptime",
    "custom/separator",
    "hyprland/language",
    "custom/separator",
    "custom/date",
    "custom/separator",
    "pulseaudio",
    "custom/separator",
    "custom/network",
    "custom/separator",
    "custom/imguipm",
    "custom/separator",
    "tray"
  ],
  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "echo {}"
  },
  "hyprland/window": {
    "format": "{}",
    "max-length": 60
  },
  "tray": {
    "icon-size": 12,
    "spacing": 5
  },
  "custom/bandwidth": {
    "exec": "bandwidth",
    "return-type": "pango",
    "interval": 1
  },
  "custom/memory": {
    "format": "M: {}",
    "exec": "memcheck",
    "return-type": "pango",
    "interval": 1
  },
  "custom/battery": {
    "format": "B: {}",
    "exec": "battery_check",
    "return-type": "pango",
    "interval": 30
  },
  "custom/network": {
    "exec": "network",
    "on-click": "network -ui",
    "return-type": "pango",
    "interval": 1
  },
  "custom/date": {
    "exec": "date +\"%I:%M:%S %d/%m/%y\"",
    "return-type": "pango",
    "interval": 1
  },
  "custom/updates": {
    "format": "P: {}",
    "exec": "imupdate -cli",
    "on-click": "imupdate -cli",
    "on-click-middle": "imupdate",
    "return-type": "pango",
    "interval": 600
  },
  "custom/uptime": {
    "format": "U: {}",
    "exec": "dayup",
    "return-type": "pango",
    "interval": 1
  },
  "pulseaudio": {
    "format": "S: {volume}%",
    "format-muted": "S: muted",
    "scroll-step": 1,
    "on-click": "pavucontrol"
  },
  "hyprland/language": {
    "format": "{}",
    "format-en": "EN",
    "format-gr": "GR",
    "on-click": "hyprctl switchxkblayout main next",
    "tooltip": false
  },
  "custom/imguipm": {
    "format": "power-menu",
    "on-click": "imguipm"
  },
  "custom/separator": {
    "format": "|",
    "interval": "once",
    "tooltip": false
  }
}
